APP_NAME=agentic-rag-demo
APP_ENV=local
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=180
LOG_MAX_FILE_SIZE_MB=20

DOCS_DIR=docs
UPLOAD_MAX_MB=20
ALLOWED_DOCUMENT_EXTENSIONS=txt,md,pdf

CHUNK_SIZE=800
CHUNK_OVERLAP=100

# OpenAI-compatible chat API.
# Qwen:     https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek: https://api.deepseek.com
# OpenAI:   https://api.openai.com/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# If EMBEDDING_BASE_URL or EMBEDDING_API_KEY is empty, the app falls back to LLM_BASE_URL/LLM_API_KEY.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=64

# Reserved for future reranking. Phase 1 uses a no-op reranker.
RERANK_PROVIDER=none
RERANK_MODEL_NAME=bge-reranker-v2-m3

MILVUS_URI=http://localhost:19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_NAME=agentic_rag_chunks
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_CONSISTENCY_LEVEL=Strong

RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.2
QUERY_MAX_CHARS=2000
